#include <tunables/global>

profile kvm-over-ip flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/python>

  # Application binary
  /app/.venv/bin/python3 ix,
  /app/.venv/bin/gunicorn ix,
  /usr/bin/python3* ix,

  # Application files (read-only)
  /app/** r,
  /app/.venv/** r,

  # Writable data directories
  /var/lib/kvm/** rw,
  /var/log/kvm-over-ip/** rw,
  /tmp/** rw,
  /app/data/** rw,

  # Device access (video and USB HID)
  /dev/video[0-9]* rw,
  /dev/bus/usb/** rw,
  /dev/ttyUSB[0-9]* rw,
  /dev/dri/** rw,
  
  # System files (read-only)
  /etc/passwd r,
  /etc/group r,
  /etc/nsswitch.conf r,
  /etc/hosts r,
  /etc/resolv.conf r,
  /proc/sys/kernel/random/uuid r,
  /proc/*/stat r,
  /proc/*/status r,
  /proc/*/cmdline r,
  /proc/meminfo r,
  /proc/cpuinfo r,
  /sys/bus/ r,
  /sys/class/ r,
  /sys/devices/** r,
  /sys/class/video4linux/** r,
  
  # Network access
  network inet stream,
  network inet dgram,
  network inet6 stream,
  network inet6 dgram,
  
  # Capabilities
  capability sys_rawio,
  capability net_bind_service,
  capability dac_override,
  capability chown,
  capability fowner,
  capability setuid,
  capability setgid,
  
  # Signals
  signal receive set=(term, kill, quit),
  signal send set=(term, kill, quit),
  
  # Deny dangerous operations
  deny /proc/sys/kernel/** w,
  deny /sys/kernel/** w,
  deny /sys/module/** w,
  deny /proc/kcore r,
  deny /boot/** rw,
  deny /root/** rw,
  deny @{HOME}/.ssh/** rw,
  deny capability sys_admin,
  deny capability sys_boot,
  deny capability sys_module,
  deny capability sys_ptrace,
  deny mount,
  deny umount,
  deny pivot_root,
  deny ptrace,
}
